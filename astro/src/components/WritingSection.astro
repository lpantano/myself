---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  talks: CollectionEntry<'talks'>[];
}

const { posts, talks } = Astro.props;
---

<section class="section writing-section" id="writing">
  <div class="container">
    <div class="writing-grid">
      <!-- Blog posts column -->
      <div class="writing-col">
        <span class="section-label">Writing</span>
        <h2 class="col-title">Posts</h2>

        <div class="post-list">
          {posts.slice(0, 6).map((post) => {
            const { title, summary, date, categories, tags } = post.data;
            const dateStr = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
            const category = (categories || tags || [])[0] || '';

            return (
              <article class="post-card">
                <div class="post-meta">
                  <time datetime={new Date(date).toISOString()} class="post-date">{dateStr}</time>
                  {category && <span class="tag-category">{category}</span>}
                </div>
                <h3 class="post-title">
                  <a href={`/blog/${post.id}/`}>{title}</a>
                </h3>
                {summary && <p class="post-summary">{summary}</p>}
              </article>
            );
          })}
        </div>

        <a href="/blog/" class="view-all-link">
          View all posts
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <!-- Divider -->
      <div class="writing-divider" aria-hidden="true"></div>

      <!-- Talks column -->
      <div class="writing-col" id="talks">
        <span class="section-label">Talks</span>
        <h2 class="col-title">Speaking</h2>

        <div class="talks-list">
          {talks.map((talk) => {
            const { title, event, date, abstract, event_url } = talk.data;
            const year = new Date(date).getFullYear();
            const shortAbstract = abstract?.slice(0, 160) + (abstract && abstract.length > 160 ? '…' : '');

            return (
              <article class="talk-card">
                <div class="talk-year-badge">{year}</div>
                <div class="talk-content">
                  <h3 class="talk-title">
                    <a href={`/talks/${talk.id}/`}>{title}</a>
                  </h3>
                  {event && (
                    <p class="talk-event">
                      {event_url ? (
                        <a href={event_url} target="_blank" rel="noopener" class="talk-event-link">{event}</a>
                      ) : event}
                    </p>
                  )}
                  {shortAbstract && <p class="talk-abstract">{shortAbstract}</p>}
                </div>
              </article>
            );
          })}
        </div>

        <a href="/talks/" class="view-all-link">
          View all talks
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .writing-section {
    background: var(--color-surface);
  }

  .writing-grid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .writing-divider {
    background: var(--color-card-border);
    align-self: stretch;
  }

  @media (max-width: 900px) {
    .writing-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .writing-divider {
      display: block;
      height: 1px;
      width: 100%;
      margin: var(--space-12) 0;
    }
  }

  .col-title {
    margin-bottom: var(--space-8);
    font-size: var(--text-2xl);
  }

  /* ---- Post cards ---- */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: var(--space-6);
  }

  .post-card {
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-card-border);
  }

  .post-card:first-child {
    border-top: 1px solid var(--color-card-border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .post-date {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .post-title {
    font-size: var(--text-md);
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: var(--space-2);
  }

  .post-title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .post-title a:hover { color: var(--color-primary); }

  .post-summary {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---- Talk cards ---- */
  .talks-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: var(--space-6);
  }

  .talk-card {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-card-border);
    align-items: start;
  }

  .talk-card:first-child {
    border-top: 1px solid var(--color-card-border);
  }

  .talk-year-badge {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-primary);
    background: var(--color-primary-light);
    border-radius: var(--radius-sm);
    padding: 3px 7px;
    text-align: center;
    margin-top: 3px;
    letter-spacing: 0.01em;
  }

  [data-theme="dark"] .talk-year-badge {
    background: rgba(0, 113, 227, 0.15);
    color: var(--color-link);
  }

  .talk-title {
    font-size: var(--text-md);
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: var(--space-1);
  }

  .talk-title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .talk-title a:hover { color: var(--color-primary); }

  .talk-event {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
    font-weight: 500;
  }

  .talk-event-link {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .talk-event-link:hover { color: var(--color-primary); }

  .talk-abstract {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* View all link */
  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    transition: gap var(--transition-fast);
    margin-top: var(--space-2);
  }

  .view-all-link:hover {
    gap: var(--space-2);
    color: var(--color-primary-dark);
  }
</style>
