      <div class="hero-community">
        <span class="community-tag">
          <span class="community-dot podcast"></span>
          Podcast Host
        </span>
        <span class="community-tag">
          <span class="community-dot wib"></span>
          Women in Bioinformatics
        </span>
        <span class="community-tag">
          <span class="community-dot nextflow"></span>
          Nextflow Maintainer
        </span>
      </div>
    </div>

    <!-- Right: photo -->
    <div class="hero-photo-wrap">
      <div class="hero-photo-bg"></div>
      <img
        src="/avatar.jpg"
        alt="Lorena Pantano"
        class="hero-photo"
        width="440"
        height="480"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    background: var(--color-bg);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
    padding-top: var(--space-12);
    padding-bottom: var(--space-12);
  }

  /* ---- Left content ---- */
  .hero-content {
    animation: fadeInUp 0.6s ease-out;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent-gold);
    margin-bottom: var(--space-4);
    letter-spacing: 0.02em;
  }

  .eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-accent-gold);
    animation: pulse-dot 2.5s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  .hero-name {
    font-size: clamp(2.5rem, 5vw, var(--text-3xl));
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.0;
    margin-bottom: var(--space-6);
    color: var(--color-text-primary);
  }

  .hero-bio {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 52ch;
    margin-bottom: var(--space-8);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
  }

  /* Social icons */
  .hero-social {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    align-items: center;
  }

  .social-link {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast), transform var(--transition-fast);
    display: flex;
    align-items: center;
  }

  .social-link:hover {
    color: var(--color-primary);
    transform: translateY(-2px);
  }

  /* Community tags */
  .hero-community {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .community-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-surface);
    padding: 4px 12px;
    border-radius: 100px;
    letter-spacing: 0.02em;
  }

  .community-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .community-dot.podcast { background: #e9427d; }
  .community-dot.wib { background: #7b5ea7; }
  .community-dot.nextflow { background: #1abc9c; }

  /* ---- Right: photo ---- */
  .hero-photo-wrap {
    position: relative;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    animation: fadeInUp 0.6s 0.15s ease-out both;
  }

  .hero-photo-bg {
    position: absolute;
    inset: -20px;
    background: var(--color-primary-light);
    border-radius: 40% 60% 55% 45% / 45% 40% 60% 55%;
    z-index: 0;
    opacity: 0.5;
    animation: morph 10s ease-in-out infinite alternate;
  }

  [data-theme="dark"] .hero-photo-bg {
    background: rgba(0, 113, 227, 0.08);
    opacity: 1;
  }

  @keyframes morph {
    0% { border-radius: 40% 60% 55% 45% / 45% 40% 60% 55%; }
    100% { border-radius: 55% 45% 40% 60% / 60% 55% 45% 40%; }
  }

  .hero-photo {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 420px;
    height: auto;
    aspect-ratio: 440 / 480;
    object-fit: cover;
    border-radius: 24px;
    box-shadow: var(--shadow-photo);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--space-12);
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-8);
    }

    .hero-content {
      order: 2;
    }

    .hero-photo-wrap {
      order: 1;
      justify-content: center;
    }

    .hero-photo {
      max-width: 260px;
    }

    .hero-eyebrow, .hero-bio, .hero-actions, .hero-social, .hero-community {
      justify-content: center;
    }

    .hero-bio { margin-left: auto; margin-right: auto; }
  }
</style>
