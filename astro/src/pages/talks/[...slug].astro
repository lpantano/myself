---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const talks = await getCollection('talks', ({ data }) => !data.draft);
  return talks.map(talk => ({
    params: { slug: talk.id },
    props: { talk },
  }));
}

const { talk } = Astro.props;
const { Content } = await render(talk);
const { title, abstract, date, event, event_url, url_video, tags } = talk.data;
---

<ArticleLayout
  title={title}
  description={abstract?.slice(0, 200)}
  date={date}
  tags={tags}
>
  {event && (
    <p class="talk-meta-event">
      <strong>Event:</strong>
      {event_url
        ? <a href={event_url} target="_blank" rel="noopener">{event}</a>
        : event}
    </p>
  )}

  {url_video && (
    <div class="talk-video">
      <a href={url_video} target="_blank" rel="noopener" class="video-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Watch recording
      </a>
    </div>
  )}

  {abstract && (
    <div class="talk-abstract-full">
      <h2>Abstract</h2>
      <p>{abstract}</p>
    </div>
  )}

  <Content />
</ArticleLayout>

<style>
  .talk-meta-event {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--color-primary);
  }

  .talk-meta-event a {
    color: var(--color-primary);
  }

  .talk-video {
    margin-bottom: var(--space-8);
  }

  .video-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 10px 20px;
    background: #ff0000;
    color: white;
    border-radius: var(--radius-sm);
    font-weight: 500;
    text-decoration: none;
    font-size: var(--text-base);
    transition: background var(--transition-fast);
  }

  .video-link:hover { background: #cc0000; color: white; }

  .talk-abstract-full {
    margin-top: var(--space-8);
  }

  .talk-abstract-full h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }
</style>
