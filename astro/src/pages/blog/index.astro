---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group by year
const byYear: Record<string, typeof posts> = {};
posts.forEach(post => {
  const year = post.data.date.getFullYear().toString();
  if (!byYear[year]) byYear[year] = [];
  byYear[year].push(post);
});
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Writing — Lorena Pantano"
  description="Posts on bioinformatics, data visualization, computational biology, and personal projects."
>
  <Nav />
  <main class="listing-main">
    <div class="container">
      <header class="listing-header">
        <span class="section-label">Writing</span>
        <h1 class="listing-title">Posts</h1>
        <p class="listing-subtitle">
          Thoughts on bioinformatics, data visualization, computational biology, and life.
        </p>
      </header>

      {years.map(year => (
        <section class="year-section">
          <h2 class="year-heading">{year}</h2>
          <div class="post-grid">
            {byYear[year].map(post => {
              const { title, summary, date, categories, tags } = post.data;
              const dateStr = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
              const category = (categories && categories.length > 0)
                ? categories[0]
                : (tags && tags.length > 0 ? tags[0] : '');

              return (
                <article class="post-card">
                  <div class="post-card-meta">
                    <time datetime={date.toISOString()} class="post-card-date">{dateStr}</time>
                    {category && <span class="tag-category">{category}</span>}
                  </div>
                  <h3 class="post-card-title">
                    <a href={`/blog/${post.id}/`}>{title}</a>
                  </h3>
                  {summary && <p class="post-card-summary">{summary}</p>}
                </article>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .listing-main {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-24);
    min-height: 100vh;
  }

  .listing-header {
    margin-bottom: var(--space-16);
  }

  .listing-title {
    margin-bottom: var(--space-3);
  }

  .listing-subtitle {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    max-width: 60ch;
  }

  .year-section { margin-bottom: var(--space-16); }

  .year-heading {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-card-border);
  }

  .post-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-card {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-card-border);
  }

  .post-card:first-child { border-top: 1px solid var(--color-card-border); }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .post-card-date {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
    min-width: 60px;
  }

  .post-card-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-2);
    line-height: 1.3;
  }

  .post-card-title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .post-card-title a:hover { color: var(--color-primary); }

  .post-card-summary {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 72ch;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
