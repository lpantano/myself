---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';

export async function getStaticPaths() {
  const items = await getCollection('portfolio');
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const { title, summary, tags, url_code, url_demo, links } = item.data;
---

<BaseLayout title={`${title} — Portfolio`} description={summary}>
  <Nav />
  <main class="portfolio-detail-main">
    <div class="container portfolio-detail-container">
      <!-- Hero image -->
      <div class="portfolio-hero-image">
        <img
          src={`/portfolio/${item.id}/featured.png`}
          alt={title}
          loading="eager"
          onerror="this.parentElement.style.background='var(--color-primary-light)'; this.style.display='none';"
        />
      </div>

      <div class="portfolio-detail-inner">
        <aside class="portfolio-sidebar">
          <div class="sidebar-tags">
            {(tags || []).map(tag => <span class="tag">{tag}</span>)}
          </div>

          <div class="sidebar-links">
            {url_code && (
              <a href={url_code} target="_blank" rel="noopener" class="sidebar-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                View Code
              </a>
            )}
            {url_demo && (
              <a href={url_demo} target="_blank" rel="noopener" class="sidebar-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                Live Demo
              </a>
            )}
            {(links || []).filter(l => l.url !== url_code && l.url !== url_demo).map(link => (
              <a href={link.url} target="_blank" rel="noopener" class="sidebar-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
                {link.name || 'View'}
              </a>
            ))}
          </div>

          <a href="/#portfolio" class="sidebar-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            All projects
          </a>
        </aside>

        <article class="portfolio-article">
          <h1 class="portfolio-article-title">{title}</h1>
          {summary && <p class="portfolio-article-summary">{summary}</p>}
          <div class="prose">
            <Content />
          </div>
        </article>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .portfolio-detail-main {
    padding-top: var(--nav-height);
    padding-bottom: var(--space-24);
    min-height: 100vh;
  }

  .portfolio-detail-container {
    max-width: 1100px;
  }

  .portfolio-hero-image {
    width: 100%;
    aspect-ratio: 21 / 9;
    background: var(--color-primary-light);
    overflow: hidden;
    margin-bottom: var(--space-12);
  }

  .portfolio-hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .portfolio-detail-inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  @media (max-width: 768px) {
    .portfolio-detail-inner {
      grid-template-columns: 1fr;
    }
    .portfolio-sidebar { order: 2; }
    .portfolio-article { order: 1; }
  }

  /* Sidebar */
  .portfolio-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + var(--space-6));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sidebar-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-primary);
    transition: all var(--transition-fast);
    justify-content: center;
  }

  .sidebar-link:hover {
    background: var(--color-primary);
    color: white;
  }

  .sidebar-back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    margin-top: var(--space-2);
  }

  .sidebar-back:hover { color: var(--color-primary); }

  /* Article */
  .portfolio-article-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--space-4);
    line-height: 1.1;
  }

  .portfolio-article-summary {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-card-border);
  }
</style>
