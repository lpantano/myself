---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const tutorials = (await getCollection('tutorials', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Videos & Tutorials — Lorena Pantano"
  description="Video tutorials on bioinformatics, data science, and career development."
>
  <Nav />
  <main class="listing-main">
    <div class="container">
      <header class="listing-header">
        <span class="section-label">Videos</span>
        <h1 class="listing-title">Tutorials & Videos</h1>
        <p class="listing-subtitle">
          Video content on bioinformatics, data science, and career development.
        </p>
      </header>

      <div class="tutorials-grid">
        {tutorials.map(tutorial => {
          const { title, summary, date, video, tags } = tutorial.data;
          const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
          const youtubeId = video?.youtube;
          const thumbnail = youtubeId
            ? `https://i.ytimg.com/vi/${youtubeId}/hqdefault.jpg`
            : null;

          return (
            <article class="tutorial-card">
              {thumbnail && (
                <a
                  href={youtubeId ? `https://youtube.com/watch?v=${youtubeId}` : '#'}
                  target="_blank"
                  rel="noopener"
                  class="tutorial-thumb-link"
                  aria-label={`Watch: ${title}`}
                >
                  <div class="tutorial-thumb">
                    <img src={thumbnail} alt={title} loading="lazy" />
                    <div class="tutorial-play">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="white" aria-hidden="true">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                </a>
              )}
              <div class="tutorial-body">
                <div class="tutorial-meta">
                  <time class="tutorial-date">{dateStr}</time>
                </div>
                <h3 class="tutorial-title">
                  {youtubeId
                    ? <a href={`https://youtube.com/watch?v=${youtubeId}`} target="_blank" rel="noopener">{title}</a>
                    : title}
                </h3>
                {summary && <p class="tutorial-summary">{summary}</p>}
                {(tags || []).length > 0 && (
                  <div class="tutorial-tags">
                    {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .listing-main {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-24);
    min-height: 100vh;
  }

  .listing-header { margin-bottom: var(--space-16); }
  .listing-title { margin-bottom: var(--space-3); }
  .listing-subtitle {
    font-size: var(--text-md);
    color: var(--color-text-secondary);
    max-width: 60ch;
  }

  .tutorials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-8);
  }

  .tutorial-card {
    background: var(--color-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-card-border);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .tutorial-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
  }

  .tutorial-thumb-link { display: block; }

  .tutorial-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface);
  }

  .tutorial-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .tutorial-card:hover .tutorial-thumb img { transform: scale(1.04); }

  .tutorial-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0.4);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .tutorial-play svg {
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
    width: 48px;
    height: 48px;
  }

  .tutorial-card:hover .tutorial-play { opacity: 1; }

  .tutorial-body {
    padding: var(--space-5);
  }

  .tutorial-meta { margin-bottom: var(--space-2); }

  .tutorial-date {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .tutorial-title {
    font-size: var(--text-md);
    font-weight: 600;
    line-height: 1.35;
    margin-bottom: var(--space-3);
  }

  .tutorial-title a {
    color: var(--color-text-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .tutorial-title a:hover { color: var(--color-primary); }

  .tutorial-summary {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tutorial-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
